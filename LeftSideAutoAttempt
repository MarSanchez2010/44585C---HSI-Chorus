void preAutonomous(void) {
  Brain.Screen.clearScreen();
  Brain.Screen.print("pre auton code");
  wait(1, seconds);

  // Only reset odometry now; no IMU-based turning
  resetOdom();
  Controller1.rumble(".-");
}

void autonomous(void){
  Drivetrain.setDriveVelocity(60, percent);
  Drivetrain.setTurnVelocity(30, percent);
  IntakeStage3.setVelocity(100, percent);
  IntakeStage2.setVelocity(100, percent);
  IntakeStage1.setVelocity(100, percent);
  wait(1, seconds);

  // Use odometry for distance, drivetrain for turns in auto

  // first: drive forward ~10"
  IntakeStage1.spin(reverse);
  IntakeStage2.spin(forward);
  driveForwardOdom(25.0, 30.0); 

  // turn right 30 degrees (drivetrain)
  Drivetrain.turnFor(left, 30, degrees);
  wait(10, msec);

  // slow drive forward ~15"
  driveForwardOdom(15.0, 20.0);

  Drivetrain.setDriveVelocity(50, percent);
  wait(50, msec);
  wait(1, seconds);
  driveBackwardOdom(1.5, 30.0); // Middle Goal Scoring

  // turn left 140 degrees (drivetrain)
  Drivetrain.turnFor(left, 90, degrees);

  Drivetrain.setDriveVelocity(60, percent);

  // drive reverse ~18"
  driveBackwardOdom(14.5, 30.0); // Middle Goal Scoring

  IntakeStage3.spin(forward);
  wait(1, seconds); // checkpoint
  IntakeStage3.stop();
  IntakeStage1.spin(reverse);
  IntakeStage2.spin(forward);

  // LONG GOAL
  // drive forward ~15" to long goal
  driveForwardOdom(23.0, 40.0);
  Drivetrain.turnFor(right, 30, degrees);
  driveForwardOdom(20.0, 40.0);
  // turn right 70 degrees
  Drivetrain.turnFor(left, 65, degrees);

  // turn left 70 degrees

  Drivetrain.setTimeout(1, seconds); 
  // drive reverse ~15"
  driveBackwardOdom(13.0, 30.0);

  IntakeStage1.spin(forward);
  IntakeStage2.spin(forward);
  IntakeStage3.spin(forward);
  wait(2, seconds);
  IntakeStage1.stop();
  IntakeStage2.stop();
  IntakeStage3.stop();
//Auto Matchloader
  Matchload.set(true);
  driveForwardOdom(26.0, 50.0);
  IntakeStage1.spin(reverse);
  IntakeStage2.spin(forward);
}

void userControl(void) {
  Brain.Screen.clearScreen();

  bool slowMode = false;      // toggle state
  bool togglePressed = false; // debounce flag
  bool wasPressed = false;    // limit switch rumble

  while (true) {

    // -------------------------
    // Slow Mode Toggle (UP)
    // -------------------------
    if (Controller1.ButtonUp.pressing() && !togglePressed) {
      slowMode = !slowMode;
      togglePressed = true;
    }
    if (!Controller1.ButtonUp.pressing()) {
      togglePressed = false;
    }

    // -------------------------
    // Tank Drive
    // -------------------------
    int leftPower = Controller1.Axis3.position();
    int rightPower = Controller1.Axis2.position();

    if (slowMode) {
      leftPower *= 0.3;
      rightPower *= 0.3;
    }

    LeftDriveSmart.spin(fwd, leftPower, pct);
    RightDriveSmart.spin(fwd, rightPower, pct);

    // -------------------------
    // Intake Controls
    // -------------------------
    IntakeStage3.setVelocity(100, percent);
    IntakeStage2.setVelocity(100, percent);
    IntakeStage1.setVelocity(100, percent);

    if (Controller1.ButtonL1.pressing()) {
      IntakeStage3.spin(forward);
    } else if (Controller1.ButtonL2.pressing()) {
      IntakeStage3.spin(reverse);
    } else {
      IntakeStage3.stop(coast);
    }

    if (Controller1.ButtonR1.pressing()) {
      IntakeStage1.spin(reverse);
      IntakeStage2.spin(forward);
    } else if (Controller1.ButtonR2.pressing()) {
      IntakeStage1.spin(forward);
      IntakeStage2.spin(reverse);
    } else {
      IntakeStage1.stop(coast);
      IntakeStage2.stop(coast);
    }

    // -------------------------
    // Pneumatics
    // -------------------------
    if (Controller1.ButtonX.pressing()) {
      Descore.set(true);
    } else if (Controller1.ButtonA.pressing()) {
      Descore.set(false);
    }

    if (Controller1.ButtonY.pressing()) {
      Matchload.set(true);
    } else if (Controller1.ButtonB.pressing()) {
      Matchload.set(false);
    }

    // -------------------------
    // Limit Switch Rumble
    // -------------------------
    bool pressed = LimitSwitchH.pressing();
    if (pressed && !wasPressed) {
      Controller1.rumble("-.-");
    }
    wasPressed = pressed;

    wait(20, msec);
  }
}

