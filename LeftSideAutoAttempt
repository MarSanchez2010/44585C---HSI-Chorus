// Odometry stuffs

// Odometry wheel constants (inches)
const double ODOM_WHEEL_DIAMETER_IN = 2.0;
const double ODOM_WHEEL_CIRCUMFERENCE_IN = M_PI * ODOM_WHEEL_DIAMETER_IN;

const int ODOM_INVERT = -1;

// Get odometry distance in inches from rotation sensor
double getOdomDistanceIn() {
  double degrees = OdomWheel.position(rotationUnits::deg);
  double revolutions = degrees / 360.0;
  double distance = revolutions * ODOM_WHEEL_CIRCUMFERENCE_IN;
  return distance * ODOM_INVERT;
}

// Reset odometry wheel position
void resetOdom() {
  OdomWheel.resetPosition();
}

// Drive forward using odometry wheel for distance
// Drive forward using odometry wheel for distance
void driveForwardOdom(double inches, double speedPct) {
  resetOdom();

  double slowDownStart = inches - 1.0;  // begin slowing 1 inch early
  if (slowDownStart < 0) slowDownStart = 0;

  // Phase 1: fast drive
  Drivetrain.setDriveVelocity(speedPct, percent);
  LeftDriveSmart.spin(forward);
  RightDriveSmart.spin(forward);

  while (fabs(getOdomDistanceIn()) < slowDownStart) {
    wait(10, msec);
  }

  // Phase 2: slow approach
  Drivetrain.setDriveVelocity(15, percent);

  while (fabs(getOdomDistanceIn()) < inches) {
    wait(10, msec);
  }

  // Phase 3: hard stop
  LeftDriveSmart.stop(hold);
  RightDriveSmart.stop(hold);
}

// Drive backward using odometry wheel for distance
void driveBackwardOdom(double inches, double speedPct) {
  resetOdom();

  double slowDownStart = inches - 1.0;  // begin slowing 1 inch early
  if (slowDownStart < 0) slowDownStart = 0;

  // Phase 1: fast drive
  Drivetrain.setDriveVelocity(speedPct, percent);
  LeftDriveSmart.spin(reverse);
  RightDriveSmart.spin(reverse);

  while (fabs(getOdomDistanceIn()) < slowDownStart) {
    wait(10, msec);
  }

  // Phase 2: slow approach
  Drivetrain.setDriveVelocity(15, percent);

  while (fabs(getOdomDistanceIn()) < inches) {
    wait(10, msec);
  }

  // Phase 3: hard stop
  LeftDriveSmart.stop(hold);
  RightDriveSmart.stop(hold);
}

