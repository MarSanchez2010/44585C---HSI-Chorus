void preAutonomous(void) {
  Brain.Screen.clearScreen();
  Brain.Screen.print("pre auton code");
  wait(1, seconds);

  //Calibrate our IMU and zero rotation; reset odometry
  IMU.calibrate();
  while (IMU.isCalibrating()) {
    wait(20, msec);
  }
  IMU.setRotation(0, degrees);
  resetOdom();
  Controller1.rumble(".-");
}

void autonomous(void) {
  Drivetrain.setDriveVelocity(60, percent);
  Drivetrain.setTurnVelocity(40, percent); // kept, though PID controls turn speed
  IntakeStage3.setVelocity(100, percent);
  IntakeStage2.setVelocity(100, percent);
  IntakeStage1.setVelocity(100, percent);

  // Use odometry for distance, IMU PID for turns in auto

  // first: drive forward 36"
  driveForwardOdom(27.0, 60.0);

  // turn left 20 degrees to absolute target -20 deg (IMU.rotation)
  turnToAnglePID(-20.0);
  wait(10, msec);

  IntakeStage1.spin(reverse);

  // slow drive forward 33"
  driveForwardOdom(12.0, 20.0);

  Drivetrain.setDriveVelocity(50, percent);
  wait(50, msec);
  IntakeStage2.spin(forward);
  wait(1, seconds);
  IntakeStage1.stop();
  IntakeStage2.stop();

  // Drivetrain lines up with the goal
  // previous: turnFor(left, 100) from -20 to -120 absolute
  turnToAnglePID(-120.0);

  Drivetrain.setDriveVelocity(60, percent);

  // drive reverse 23"
  driveBackwardOdom(10.0, 60.0); //Middle GOal Scoring

  IntakeStage3.spin(forward);
  wait(1, seconds);
  IntakeStage3.stop();
  IntakeStage1.spin(reverse);
  IntakeStage2.spin(forward);

  // drive forward 60"
  driveForwardOdom(30.0, 60.0);

  // previous: turnFor(right, 45) from -120 to -75 absolute
  turnToAnglePID(-75.0);

  // drive forward 23"
  driveForwardOdom(10.0, 60.0);

  // previous: turnFor(left, 75) from -75 -> -150 absolute
  turnToAnglePID(-150.0);

  Drivetrain.setTimeout(1, seconds); 
  // drive reverse 25"
  driveBackwardOdom(25.0, 60.0);

  IntakeStage1.spin(forward);
  IntakeStage2.spin(forward);
  IntakeStage3.spin(forward);
  wait(3, seconds);
  IntakeStage1.stop();
  IntakeStage2.stop();
  IntakeStage3.stop();

  Drivetrain.setDriveVelocity(50, percent);

  // small forward and back 10"
  driveForwardOdom(10.0, 50.0);
  driveBackwardOdom(10.0, 50.0);

  Matchload.set(true);
}

void userControl(void) {
  Brain.Screen.clearScreen();

  bool slowMode = false;      // toggle state
  bool togglePressed = false; // debounce flag
  bool wasPressed = false;    // limit switch rumble

  while (true) {

    // -------------------------
    // Slow Mode Toggle (UP)
    // -------------------------
    if (Controller1.ButtonUp.pressing() && !togglePressed) {
      slowMode = !slowMode;
      togglePressed = true;
    }
    if (!Controller1.ButtonUp.pressing()) {
      togglePressed = false;
    }

    // -------------------------
    // Tank Drive
    // -------------------------
    int leftPower = Controller1.Axis3.position();
    int rightPower = Controller1.Axis2.position();

    if (slowMode) {
      leftPower *= 0.3;
      rightPower *= 0.3;
    }

    LeftDriveSmart.spin(fwd, leftPower, pct);
    RightDriveSmart.spin(fwd, rightPower, pct);

    // -------------------------
    // Intake Controls
    // -------------------------
    IntakeStage3.setVelocity(100, percent);
    IntakeStage2.setVelocity(100, percent);
    IntakeStage1.setVelocity(100, percent);

    if (Controller1.ButtonL1.pressing()) {
      IntakeStage3.spin(forward);
    } else if (Controller1.ButtonL2.pressing()) {
      IntakeStage3.spin(reverse);
    } else {
      IntakeStage3.stop(coast);
    }

    if (Controller1.ButtonR1.pressing()) {
      IntakeStage1.spin(reverse);
      IntakeStage2.spin(forward);
    } else if (Controller1.ButtonR2.pressing()) {
      IntakeStage1.spin(forward);
      IntakeStage2.spin(reverse);
    } else {
      IntakeStage1.stop(coast);
      IntakeStage2.stop(coast);
    }

    // -------------------------
    // Pneumatics
    // -------------------------
    if (Controller1.ButtonX.pressing()) {
      Descore.set(true);
    } else if (Controller1.ButtonA.pressing()) {
      Descore.set(false);
    }

    if (Controller1.ButtonY.pressing()) {
      Matchload.set(true);
    } else if (Controller1.ButtonB.pressing()) {
      Matchload.set(false);
    }

    // -------------------------
    // Limit Switch Rumble
    // -------------------------
    bool pressed = LimitSwitchH.pressing();
    if (pressed && !wasPressed) {
      Controller1.rumble("-.-");
    }
    wasPressed = pressed;

    wait(20, msec);
  }
}

