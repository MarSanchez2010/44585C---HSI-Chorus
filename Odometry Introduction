// Odometry and PID stuffs

// Odometry wheel constants (inches)
const double ODOM_WHEEL_DIAMETER_IN = 2.0;
const double ODOM_WHEEL_CIRCUMFERENCE_IN = M_PI * ODOM_WHEEL_DIAMETER_IN;

const int ODOM_INVERT = -1;

// Get odometry distance in inches from rotation sensor
double getOdomDistanceIn() {
  double degrees = OdomWheel.position(rotationUnits::deg);
  double revolutions = degrees / 360.0;
  double distance = revolutions * ODOM_WHEEL_CIRCUMFERENCE_IN;
  return distance * ODOM_INVERT;
}

// Reset odometry wheel position
void resetOdom() {
  OdomWheel.resetPosition();
}

// Drive forward using odometry wheel for distance
void driveForwardOdom(double inches, double speedPct) {
  resetOdom();
  Drivetrain.setDriveVelocity(speedPct, percent);

  LeftDriveSmart.spin(forward);
  RightDriveSmart.spin(forward);

  while (fabs(getOdomDistanceIn()) < inches) {
    wait(10, msec);
  }

  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
}

// Drive backward using odometry wheel for distance
void driveBackwardOdom(double inches, double speedPct) {
  resetOdom();
  Drivetrain.setDriveVelocity(speedPct, percent);

  LeftDriveSmart.spin(reverse);
  RightDriveSmart.spin(reverse);

  while (fabs(getOdomDistanceIn()) < inches) {
    wait(10, msec);
  }

  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
}

// *** NEW *** PID turning using IMU (absolute angle, based on IMU.rotation())

double kP_turn = 0.9;
double kI_turn = 0.0;
double kD_turn = 0.2;

double turnIntegralLimit = 10.0;   // degrees
double turnTolerance = 1.0;        // degrees
double turnMaxSpeed = 70.0;        // percent
double turnMinSpeed = 5.0;         // percent
double turnTimeoutMsPer90 = 2000;  // rough timeout scaling

void turnToAnglePID(double targetAngleDeg) {
  // IMU.rotation() will be treated as 0 at start of auton
  double error = 0.0;
  double lastError = 0.0;
  double integral = 0.0;
  double derivative = 0.0;

  // Simple timeout based on magnitude of turn
  double absTarget = fabs(targetAngleDeg);
  double timeoutMs = (absTarget / 90.0) * turnTimeoutMsPer90;
  if (timeoutMs < 800) timeoutMs = 800; // minimum timeout

  timer t;
  t.reset();

  while (true) {
    double currentAngle = IMU.rotation(degrees);
    error = targetAngleDeg - currentAngle;

    if (fabs(error) <= turnTolerance) {
      break;
    }

    // Timeout safety
    if (t.time(msec) > timeoutMs) {
      break;
    }

    // Integral with simple anti-windup
    if (fabs(error) < turnIntegralLimit) {
      integral += error * 0.01; // scaled by loop time (~10ms)
    } else {
      integral = 0;
    }

    derivative = error - lastError;
    lastError = error;

    double output = kP_turn * error + kI_turn * integral + kD_turn * derivative;

    // Clamp output to max speed
    if (output > turnMaxSpeed) output = turnMaxSpeed;
    if (output < -turnMaxSpeed) output = -turnMaxSpeed;

    // Ensure we don't stall with too low power
    if (output > 0 && fabs(output) < turnMinSpeed) output = turnMinSpeed;
    if (output < 0 && fabs(output) < turnMinSpeed) output = -turnMinSpeed;

    LeftDriveSmart.spin(directionType::fwd, output, percent);
    RightDriveSmart.spin(directionType::rev, output, percent);

    wait(10, msec);
  }

  LeftDriveSmart.stop(brake);
  RightDriveSmart.stop(brake);
}
